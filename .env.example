# =====================================================================
# IQ-EQ Unified Agent Mesh - Environment Configuration Template
# Copy this file to '.env' at the repository root and fill in your keys.
# =====================================================================

# --- Primary OpenRouter Configuration (Required for POC2 and POC3) ---
OPENROUTER_API_KEY="your_openrouter_api_key_here"
OPENROUTER_MODEL="anthropic/claude-3.5-sonnet"

# --- POC Specific Model Overrides (Optional) ---
# POC2_LLM_MODEL="anthropic/claude-3.5-sonnet"
# POC3_LLM_MODEL="anthropic/claude-3.5-sonnet"

# --- POC1 Reasoning Model Configuration (Optional) ---
# Order of priority: GOOGLE_API_KEY -> OPENAI_API_KEY -> GROQ_API_KEY -> OPENROUTER
GOOGLE_API_KEY="your_gemini_api_key_here"
# OPENAI_API_KEY="your_openai_api_key_here"
# GROQ_API_KEY="your_groq_api_key_here"
